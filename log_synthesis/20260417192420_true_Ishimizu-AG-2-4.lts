//*  ArtGallery.mtsa (for MTSA)
//*  Create Date      : 2019/06/19
//*  Creator Name     : Takuto Yamauchi
//*  Example          : Physical Security(ArtGallery)
//*  MTSA run command : [java -jar -Xmx100G mtsa.jar]
//*****************************************************************************/

//*****************************************************************************
// Environment
//*****************************************************************************

const N = 4

set VisitorAction = {reqEnter_Hall,reqEnter_A,reqOut}
set LockAction    = {lock_Hall,lock_A,unlock_Hall,unlock_A}
set AllowAction   = {allow_Hall,allow_A}
set DenyAction    = {deny_Hall,deny_A}
set DoorAction    = {LockAction,AllowAction,DenyAction,resRoomStatus}
set MonitorAction = {notEnter,arrive_Hall[1..N],arrive_A[1..N],leave}

/* VISITOR_BAD : このままだとThere is no controller */
VISITOR_BAD = VISIT,
VISIT =
(
	reqEnter_Hall  -> CHECK_HALL
    |reqEnter_A    -> CHECK_A
    |reqOut        -> CHECK_OUT
),
CHECK_HALL = (allow_Hall -> arrive_Hall[1..N] -> VISIT | deny_Hall -> notEnter -> VISIT),
CHECK_A    = (allow_A    -> arrive_A[1..N]    -> VISIT | deny_A    -> arrive_Hall[1..N] -> VISIT),
CHECK_OUT  = (leave      -> VISIT).

/* VISITOR_BADをVISITOR_GOODにすればControllerが作れる */
/*
VISITOR_GOOD = VISIT,
VISIT =
(
	reqEnter_Hall  -> check_Hall -> CHECK_HALL
    |reqEnter_A    -> check_A -> CHECK_A
    |reqOut        -> CHECK_OUT
),
CHECK_HALL = (allow_Hall -> arrive_Hall[1..N] -> VISIT | deny_Hall -> notEnter -> VISIT),
CHECK_A    = (allow_A    -> arrive_A[1..N]    -> VISIT | deny_A    -> arrive_Hall[1..N] -> VISIT),
CHECK_OUT  = (leave      -> VISIT).
*/

HALL = HALL[0],
HALL[n:0..N]   = (when(n!=N) allow_Hall -> arrive_Hall[n+1] -> HALL[n+1]   |when(n!=N) deny_A -> arrive_Hall[n+1] -> HALL[n+1]  |when(n!=0) reqEnter_A -> HALL[n-1]).
ROOM_A = ROOM_A[0],
ROOM_A[n:0..N] = (when(n!=N) allow_A    -> arrive_A[n+1]    -> ROOM_A[n+1] |when(n!=0) reqOut -> ROOM_A[n-1]).


DOOR_HALL = UNLOCKED,
UNLOCKED = (allow_Hall  -> UNLOCKED
		   |lock_Hall   -> LOCKED),
LOCKED   = (deny_Hall  -> LOCKED
		   |unlock_Hall -> UNLOCKED).

DOOR_A = UNLOCKED,
UNLOCKED = (allow_A  -> UNLOCKED
		   |lock_A   -> LOCKED),
LOCKED   = (deny_A  -> LOCKED
		   |unlock_A -> UNLOCKED).


/* VISITOR_BADに以下のモデルを並列合成するとVISITOR_GOODになる */
/* 以下モデルをLLMで自動合成したい */
CONTROL_HALL = Q1,
Q1 = (reqEnter_Hall -> Q2),
Q2 = (check_Hall -> Q3),
Q3 = ({allow_Hall, deny_Hall} -> Q1).  

CONTROL_A = Q1,
Q1 = (reqEnter_A -> Q2),
Q2 = (check_A -> Q3),
Q3 = ({allow_A, deny_A} -> Q1). 

||BadEnvironment  = (VISITOR_BAD||HALL||ROOM_A||DOOR_HALL||DOOR_A).
||GoodEnvironment = (VISITOR_BAD||HALL||ROOM_A||DOOR_HALL||DOOR_A||CONTROL_HALL||CONTROL_A).
//||GoodEnvironment = (VISITOR_GOOD||HALL||ROOM_A||DOOR_HALL||DOOR_A).

//*****************************************************************************
// Requirement
//*****************************************************************************

/*Threshold*/
const TH_HALL = 2
const TH_A    = 2

ltl_property LIMIT_HALL = [](!arrive_Hall[TH_HALL])
ltl_property LIMIT_A    = [](!arrive_A[TH_A])


controllerSpec Specification =
{
	safety       = {
					LIMIT_HALL,
					LIMIT_A,
				   }
	//liveness     = {GOAL}
	controllable = {LockAction,check_Hall,check_A}
}


//*****************************************************************************
//Controller
//*****************************************************************************

//Isimizu: Bad
controller ||BadController  = (BadEnvironment)~{Specification}.

//Ishimizu: Good
controller ||GoodController = (GoodEnvironment)~{Specification}.
