
ENV = E0,
E0 = (approach -> E1),
E1 = (open -> E2),
E2 = (pass -> E3),
E3 = (close -> E0).


fluent PeoplePresent = <approach, pass_done>
fluent DoorOpen = <open, close>


ltl_property SAFETY1 = [](PeoplePresent -> !close)        // 人がいるのにドアを閉じてはいけない
ltl_property SAFETY2 = [](!DoorOpen -> !pass)                 // ドアが開いていないと通過してはいけない


controllerSpec Requirement =
{
  safety = { SAFETY1, SAFETY2 }
  controllable = {open, close}
}

controller ||Controller = (ENV)~{Requirement}