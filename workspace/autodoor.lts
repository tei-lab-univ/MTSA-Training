ENV = E0,
E0 = (approach -> E1),
E1 = (open -> E2),
E2 = (pass -> E3 | close -> E0),
E3 = (pass_done -> E2).

||Environment_Model = (ENV).


fluent PeoplePresent = <approach, pass_done>
fluent DoorOpen = <pass_done, close>


ltl_property SAFETY = [](PeoplePresent -> !close)        // 人がいるのにドアを閉じてはいけない


controllerSpec Requirement =
{
  safety = {SAFETY}
  controllable = {open, close}
}

controller ||Controller = (ENV)~{Requirement}.
