range N = 0..3

ACTION = STAY,
STAY = (start -> STATE[0]),
STATE[n:N] = (
    when(n < 3) inc[n+1] -> STATE[n+1]
  | when(n > 0) dec[n-1] -> STATE[n-1]
).

||ENV = (ACTION).

fluent FF = <inc[1], inc[2]>
ltl_property SAFETY0 = [](FF -> !inc[3])

controllerSpec Requirement =
{
  safety = {SAFETY0}
  controllable = {start}
}

controller ||Controller = (ENV)~{Requirement}.
